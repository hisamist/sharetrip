# Copier ce fichier en .env et adapter les valeurs

# Base de données
DATABASE_URL=postgresql://sharetrip:sharetrip@localhost:5432/sharetrip

# Redis
REDIS_URL=redis://localhost:6379/0

# API de change
FRANKFURTER_BASE_URL=https://api.frankfurter.app
CURRENCY_CACHE_TTL=86400

# Cache Repository
REPO_CACHE_TTL=300

# Auth — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_EXPIRE_MINUTES=1440

# App
APP_ENV=development
